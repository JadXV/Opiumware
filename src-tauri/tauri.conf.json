{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Opiumware",
  "version": "1.0.0",
  "identifier": "com.norbyv1.opiumware",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "title": "Opiumware",
        "width": 1280,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
